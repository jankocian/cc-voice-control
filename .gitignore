# Build output: only the committed, self-contained plugin bundle is tracked.
dist/*
!dist/daemon/
dist/daemon/*
!dist/daemon/mcp-server.js
# The phone SPA build output (regenerated by `vite build`; deployed, not committed).
web/dist/
# No trailing slash so this also ignores a `node_modules` *symlink* (a file) — e.g. one
# pointing a git worktree at the main checkout's deps; `node_modules/` would miss it.
node_modules
.wrangler/
.dev.vars
*.log
.playwright-mcp/
.claude/settings.local.json
.claude/worktrees/
.env*